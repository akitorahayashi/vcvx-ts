{
  "name": "vcvx-ts",
  "version": "0.1.0",
  "description": "Bun and TypeScript client for the VOICEVOX engine API",
  "license": "UNLICENSED",
  "packageManager": "bun@1.3.14",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "serve": "docker run --rm --init -p 127.0.0.1:50021:50021 --name vcvx-voicevox voicevox/voicevox_engine:cpu-ubuntu22.04-0.25.2",
    "s": "bun run serve",
    "docs:api": "bun scripts/generate-api-reference.ts",
    "measure:duration": "bun scripts/measure-duration.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && bun run typecheck",
    "fix": "biome check --write ."
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  }
}
