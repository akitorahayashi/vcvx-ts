{
  "name": "bun-client",
  "version": "0.1.0",
  "description": "Bun and TypeScript API client template",
  "license": "UNLICENSED",
  "packageManager": "bun@1.3.14",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && bun run typecheck",
    "fix": "biome check --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.14",
    "husky": "9.1.7",
    "typescript": "6.0.3"
  }
}
